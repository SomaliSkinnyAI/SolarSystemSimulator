{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "noEmit": true
  },
  "include": ["src"]
}
